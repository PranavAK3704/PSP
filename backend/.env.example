# ── Valmo Partner Support Platform — backend env ─────────────────────────────
# You do NOT need to create this — backend/.env already exists with a working
# key for the active provider. This file just documents what's needed.

# ACTIVE brain: OpenAI via the gateway (gpt-5.5 on every tier). Required.
OPENAI_API_KEY=your-openai-gateway-key

# Alternative providers — set the matching key AND flip `provider:` in
# config/models.yaml (provider: gemini | claude). No code change either way.
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# ── NOT USED by the demo (documented for production only) ────────────────────
# The real data substrate connectors read these once they replace the mock.
# Kapture is being REPLACED by this platform — it is not an upstream source.
# LOG10_API_BASE=
# LOG10_API_KEY=
# PAYMENTS_LEDGER_URL=
